# Keep the build context (and final image) small.
.git
.gitignore
.dockerignore
Dockerfile
README.md

# Tests and dev-only deps never belong in the runtime image.
tests/
requirements-dev.txt

# Deploy-time / CI-time only — not part of the runtime image.
deploy/
scripts/
Makefile
pyproject.toml
.harness/

# Python caches / virtualenvs / build artifacts.
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
sbom.cdx.json
.venv/
venv/
.env

# Editor / OS noise.
.vscode/
.idea/
.DS_Store
*.png
